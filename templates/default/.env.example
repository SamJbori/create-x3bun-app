# Production Database
DATABASE_URL="postgres://<username>:<password>@<SomeServer>:<SomePort>/<DBName>?<x>=<someting>"

# Better auth url
BETTER_AUTH_URL="http://localhost:3000"
# Better auth secret use `openssl rand -base64 32`
BETTER_AUTH_SECRET="somelongandcomplicatedencryptionkeythatwillbeusedbybetterauthforencryptingcredintials"
# Better auth Mongo DB URL
AUTH_DB_URL="mongodb+srv://<username>:<password>@<DBName>:<SomePort>/<DBName>?appName=<SomeApp>"
# Better auth Table name
AUTH_TABLE_NAME="auth"

# S3 Config, EP can be undefined
# S3_ENDPOINT="https://some.string.com"
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# For SSR communication
SERVER_TOKEN=""

# CloudFlare Turnstile Secret Key
CF_TURNSTILE_SECRET_KEY="vvv"

# Backend Server Address
X3BUN_BE_URL="http://localhost:3006"