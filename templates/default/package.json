{
	"name": "x3bun",
	"private": true,
	"scripts": {
		"clean": "git clean -xdf node_modules",
		"clean:workspaces": "turbo run clean",
		"dev": "turbo run dev",
		"exports": "turbo run exports",
		"format": "biome format .",
		"format:fix": "biome format . --write",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"lint:ws": "bunx --bun sherif@latest",
		"lint:ws:fix": "bunx --bun sherif@latest --fix",
		"typecheck": "turbo run typecheck",
		"postinstall": "bun run --bun turbo/scripts/postinstall.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"turbo": "^2.9.14",
		"typescript": "6.0.3"
	},
	"engines": {
		"node": ">=22"
	},
	"workspaces": [
		"apps/*",
		"packages/*",
		"tooling/*"
	]
}